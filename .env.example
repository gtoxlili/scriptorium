# Copy to `.env` and edit for your host. `.env` is gitignored.

# Absolute path to where workspace state lives. On macOS with an
# external SSD, something like:
#   SCRIPTORIUM_WORKSPACE_ROOT=/Volumes/Lexar1TB/scriptorium-state
# On internal disk (simpler, no TCC prompt issue for Docker but works
# fine natively too):
#   SCRIPTORIUM_WORKSPACE_ROOT=/Users/influo/.local/share/scriptorium-state
SCRIPTORIUM_WORKSPACE_ROOT=/Volumes/YOUR_SSD/scriptorium-state

# Optional — path to the host's Docker daemon socket. OrbStack default shown.
#SCRIPTORIUM_DOCKER_SOCK=/Users/influo/.orbstack/run/docker.sock

# Optional — path to the runtime config file. Defaults to deploy/config.toml.
#SCRIPTORIUM_CONFIG=./deploy/config.toml

# Optional — host port to expose the gRPC server on (always bound to 127.0.0.1).
#SCRIPTORIUM_PORT=50051
